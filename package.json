{
  "name": "memory-brain",
  "version": "0.1.0",
  "description": "Local-first long-term memory CLI for AI coding agents, with recall, remember, and session handoff.",
  "type": "module",
  "main": "./dist/src/cli.js",
  "types": "./dist/src/cli.d.ts",
  "bin": {
    "memory-brain": "./dist/src/cli.js"
  },
  "files": [
    "dist",
    "skill",
    "README.md",
    "LICENSE",
    "install.sh"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "node --test --test-concurrency=1 dist/test/**/*.test.js",
    "test:src": "tsx --test test/**/*.test.ts"
  },
  "keywords": [
    "memory",
    "long-term-memory",
    "agent",
    "ai-agent",
    "coding-agent",
    "cli",
    "sqlite",
    "local-first",
    "rag",
    "recall",
    "codex",
    "claude"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "commander": "^14.0.0",
    "openai": "^5.20.2",
    "smol-toml": "^1.3.1",
    "sql.js": "^1.14.1",
    "toml": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/sql.js": "^1.4.9",
    "tsx": "^4.20.3",
    "typescript": "^5.8.2"
  }
}
